<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>hk.tonylee.touchguard</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>-lc</string>
        <string>exec "$HOME/bin/TouchGuard" -time 0.2 -nodebug</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/tonylee/Library/Logs/TouchGuard.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/tonylee/Library/Logs/TouchGuard.err.log</string>
</dict>
</plist>
